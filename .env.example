# ── elayra-research .env.example ─────────────────────────────────────────────
# Copy this file to  .env  and adjust the values for the target machine.
# It is ignored by git already.

# ── Python / virtualenv ──────────────────────────────────────────────────────
# Use a specific Python minor version. Leave empty if the correct interpreter
# is already available on PATH.
UV_PYTHON=3.11

# Force CPU-only execution (set to empty string to allow CUDA).
# Useful when the target machine has no NVIDIA GPU or no CUDA runtime.
CUDA_VISIBLE_DEVICES=

# Reduce thread oversubscription on limited-RAM or limited-core machines.
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2

# ── Hugging Face / transformers ──────────────────────────────────────────────
# Optional: local cache directory for models and datasets.
# Comment out to use the default Hugging Face cache location.
HF_HOME=.huggingface

# Avoid tokenizers fork warnings on some Windows setups.
TOKENIZERS_PARALLELISM=false

# ── Project behaviour ────────────────────────────────────────────────────────
# Enable optional extended model set in run_pipeline.py.
# 1 = include extra models beyond the primary 15.
# 0 = primary 15 models only.
INCLUDE_OPTIONAL_MODELS=0

# ── Runtime / logging ────────────────────────────────────────────────────────
# Unbuffered Python stdout/stderr so logs are visible in real time.
PYTHONUNBUFFERED=1

# Matplotlib backend for headless / CI / Windows without display.
MPLBACKEND=Agg
